{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommitTypeAll(chore)",
    ":dependencyDashboard"
  ],
  "rangeStrategy": "bump",
  "lockFileMaintenance": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "groupName": "github-actions",
      "automerge": false
    },
    {
      "matchManagers": ["cargo"],
      "matchUpdateTypes": ["patch", "minor"],
      "groupName": "cargo non-major"
    },
    {
      "matchManagers": ["cargo"],
      "matchUpdateTypes": ["major"],
      "addLabels": ["dependencies", "major"]
    }
  ],
  "prHourlyLimit": 4,
  "prConcurrentLimit": 8
}
