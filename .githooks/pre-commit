#!/usr/bin/env bash
set -euo pipefail
shopt -s nullglob

check_tool() {
  if command -v "$1" >/dev/null 2>&1; then return 0; fi
  echo "warning: $1 not found; skipping $2" >&2
  [ -n "${3:-}" ] && echo "  install: $3" >&2
  return 1
}

if command -v cargo >/dev/null 2>&1; then
  cargo fmt --all -- --check
  cargo test
  cargo clippy --all-targets -- -D warnings
fi

# Python: lint + format check.
if check_tool ruff "Python lint/format checks" "uv tool install ruff"; then
  ruff check tools/
  ruff format --check tools/
fi

# Shell: format + static analysis.
if check_tool shfmt "shell format check" "go install mvdan.cc/sh/v3/cmd/shfmt@latest"; then
  shfmt -d -i 2 -ci scripts/*.sh .githooks/pre-commit .githooks/commit-msg
fi

if check_tool shellcheck "shell static analysis" "see https://github.com/koalaman/shellcheck#installing"; then
  shellcheck -S style scripts/*.sh .githooks/pre-commit .githooks/commit-msg
fi

# TOML: format check.
if check_tool taplo "TOML format check" "cargo install taplo-cli --locked"; then
  taplo fmt --check
fi

if check_tool gitleaks "local secret scan" ""; then
  gitleaks protect --staged --redact --verbose
fi
